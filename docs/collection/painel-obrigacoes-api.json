              "path": ["api", "dashboard", "alertas"]
            },
            "description": "Retorna lista de alertas: obrigações vencendo em até 30 dias ou já atrasadas, ordenadas por urgência.\n\nDados cacheados em Redis por 60s (TTL). Cache é invalidado automaticamente quando uma obrigação é marcada como entregue."
          },
          "response": [
            {
              "name": "Alertas",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"\",\n  \"data\": [\n    {\n      \"id\": \"b2c3d4e5-...\",\n      \"empresaId\": \"a1b2c3d4-...\",\n      \"razaoSocial\": \"Empresa Exemplo Ltda\",\n      \"cnpj\": \"11222333000181\",\n      \"tipoNome\": \"DAS\",\n      \"dataVencimento\": \"2026-06-10T00:00:00\",\n      \"diasRestantes\": 2,\n      \"status\": 1\n    },\n    {\n      \"id\": \"c3d4e5f6-...\",\n      \"empresaId\": \"a1b2c3d4-...\",\n      \"razaoSocial\": \"Empresa Exemplo Ltda\",\n      \"cnpj\": \"11222333000181\",\n      \"tipoNome\": \"DCTF\",\n      \"dataVencimento\": \"2026-06-01T00:00:00\",\n      \"diasRestantes\": -7,\n      \"status\": 2\n    }\n  ],\n  \"errorCode\": null\n}"
            }
          ]
